# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# Your Gemini API key — stays on the server, never sent to the browser.
GEMINI_API_KEY=your_gemini_api_key_here

# Port the Express server listens on (default: 3001)
PORT=3001

# The frontend origin allowed to call this proxy.
# In production set this to your actual domain, e.g. https://equiminds.ai
ALLOWED_ORIGIN=http://localhost:3000
